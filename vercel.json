{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/images/(.*)", "dest": "/frontend/images/$1" },
    { "src": "/admin.html", "dest": "/frontend/admin.html" },
    { "src": "/(.*\\.(?:html|css|js|jpg|jpeg|png|svg|ico|webp))", "dest": "/frontend/$1" },
    { "src": "/(.*)", "dest": "/api/index.js" }
  ]
}
